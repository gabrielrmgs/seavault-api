POSTGRES_DB=seavault
POSTGRES_USER=seavault
POSTGRES_PASSWORD=troque-esta-senha

DB_URL=jdbc:postgresql://db:5432/seavault
DB_USER=seavault
DB_PASSWORD=troque-esta-senha

JWT_PRIVATE_KEY_LOCATION=/deployments/secrets/privateKey.pem
SEAVAULT_CORS_ORIGINS=https://app.seavault.com.br
SEAVAULT_PII_KEY=troque-por-uma-chave-base64-de-32-bytes
SEAVAULT_FILES_DIR=/deployments/data/files
SEAVAULT_APP_BASE_URL=https://api.seavault.com.br

# Resend SMTP (https://resend.com/settings/api-keys)
# Dominio remetente deve estar verificado em resend.com/domains
QUARKUS_MAILER_HOST=smtp.resend.com
QUARKUS_MAILER_PORT=587
QUARKUS_MAILER_USERNAME=resend
QUARKUS_MAILER_PASSWORD=re_xxxxxxxxxxxxxxxx
QUARKUS_MAILER_START_TLS=REQUIRED
